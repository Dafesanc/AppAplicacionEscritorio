<UserControl x:Class="GestionComercial.Presentation.Views.Modules.VehiculosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GestionComercial.Presentation.ViewModels.Modules">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== BARRA SUPERIOR ===== -->
        <Border Grid.Row="0" Background="White" Padding="20,14"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Búsqueda -->
                <Border Grid.Column="0" BorderBrush="#D1D5DB" BorderThickness="1"
                        CornerRadius="6" Height="36" Margin="0,0,12,0" MaxWidth="340"
                        HorizontalAlignment="Left">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="13"
                                   Margin="10,0,6,0" VerticalAlignment="Center"
                                   Foreground="#9CA3AF"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding FiltroBusqueda, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent"
                                 FontSize="13" VerticalContentAlignment="Center"
                                 Margin="0,0,8,0"/>
                    </Grid>
                </Border>

                <!-- Filtro estado -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding EstadosFiltro}"
                          SelectedItem="{Binding FiltroEstado}"
                          Style="{StaticResource InputComboStyle}"
                          Width="150" Height="36" Margin="0,0,12,0"/>

                <!-- Botón nuevo -->
                <Button Grid.Column="2"
                        Command="{Binding NuevoVehiculoCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="150" Height="36">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="16" Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Nuevo Vehículo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== CONTENIDO ===== -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding MostrarFormulario, Converter={StaticResource BoolVis}, ConverterParameter=0}"/>
            </Grid.ColumnDefinitions>

            <!-- Tabla de vehículos -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#000" Opacity="0.06"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Título tabla -->
                    <Border Grid.Row="0" Padding="16,12" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚛" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Vehículos Registrados"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#1E3A5F" VerticalAlignment="Center"/>
                            <Border Background="#EFF6FF" CornerRadius="10" Padding="8,2" Margin="12,0,0,0">
                                <TextBlock Text="{Binding Vehiculos.Count, StringFormat='{}{0} registros'}"
                                           FontSize="11" Foreground="#3B82F6"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Loading overlay -->
                    <Border Grid.Row="1" Background="#80FFFFFF"
                            Visibility="{Binding EstaCargando, Converter={StaticResource BoolVis}}"
                            Panel.ZIndex="10">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Cargando..." FontSize="14" Foreground="#6B7280"/>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Vehiculos}"
                              SelectedItem="{Binding VehiculoSeleccionado}"
                              Style="{StaticResource ModernDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Placa"   Binding="{Binding Placa}"        Width="90"/>
                            <DataGridTextColumn Header="Tipo"    Binding="{Binding Tipo}"          Width="90"/>
                            <DataGridTextColumn Header="Cliente" Binding="{Binding ClienteNombre}" Width="*"/>
                            <DataGridTextColumn Header="Marca"   Binding="{Binding Marca}"         Width="90"/>
                            <DataGridTextColumn Header="Modelo"  Binding="{Binding Modelo}"        Width="90"/>
                            <DataGridTextColumn Header="Cap. (t)"
                                                Binding="{Binding CapacidadTon, StringFormat='{}{0:F2}'}"
                                                Width="70"/>
                            <DataGridTextColumn Header="Tara (kg)"
                                                Binding="{Binding PesoTaraKg, StringFormat='{}{0:F0}'}"
                                                Width="80"/>
                            <DataGridTemplateColumn Header="Estado" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left"
                                                Background="{Binding Estado, Converter={StaticResource EstadoColorConverter}}">
                                            <TextBlock Text="{Binding Estado}" FontSize="11"
                                                       Foreground="White" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Acciones" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✏ Editar"
                                                    Command="{Binding DataContext.EditarVehiculoCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#1E3A5F" FontSize="11"
                                                    Cursor="Hand" Margin="0,0,6,0"/>
                                            <Button Content="{Binding Estado,
                                                        Converter={StaticResource BoolToActiveTagConverter}}"
                                                    Command="{Binding DataContext.CambiarEstadoCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#6B7280" FontSize="11"
                                                    Cursor="Hand"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Panel formulario -->
            <Border Grid.Column="1"
                    Background="White" CornerRadius="8"
                    Width="340"
                    Visibility="{Binding MostrarFormulario, Converter={StaticResource BoolVis}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#000" Opacity="0.06"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- Título formulario -->
                        <TextBlock Text="{Binding TituloFormulario}"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#1E3A5F" Margin="0,0,0,16"/>

                        <!-- Mensaje error/éxito -->
                        <Border Background="#FEF2F2" CornerRadius="6" Padding="10,8" Margin="0,0,0,10"
                                Visibility="{Binding MensajeError, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{Binding MensajeError}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Cliente -->
                        <TextBlock Text="Cliente *" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#374151" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Clientes}"
                                  SelectedValuePath="IdCliente"
                                  SelectedValue="{Binding FormIdCliente}"
                                  DisplayMemberPath="Nombre"
                                  Style="{StaticResource InputComboStyle}"
                                  Margin="0,0,0,12"/>

                        <!-- Placa -->
                        <TextBlock Text="Placa *" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#374151" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormPlaca, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputStyle}"
                                 IsEnabled="{Binding EsEdicion, Converter={StaticResource InverseBoolConverter}}"
                                 CharacterCasing="Upper"
                                 Margin="0,0,0,12"/>

                        <!-- Tipo -->
                        <TextBlock Text="Tipo *" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#374151" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding TiposVehiculo}"
                                  SelectedItem="{Binding FormTipo}"
                                  Style="{StaticResource InputComboStyle}"
                                  Margin="0,0,0,12"/>

                        <!-- Marca / Modelo -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Marca" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#374151" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormMarca, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Modelo" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#374151" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormModelo, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Color / Año -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Color" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#374151" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormColor, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Año" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#374151" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormAno, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Capacidad / Tara -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Cap. (ton)" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#374151" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormCapacidad, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Tara (kg)" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#374151" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding FormPesoTara, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- VIN -->
                        <TextBlock Text="VIN / Chasis" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#374151" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormVin, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputStyle}"
                                 Margin="0,0,0,12"/>

                        <!-- Observaciones -->
                        <TextBlock Text="Observaciones" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#374151" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormObservaciones, UpdateSourceTrigger=PropertyChanged}"
                                 Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Padding="10,8"
                                 FontSize="13" BorderBrush="#D1D5DB"
                                 BorderThickness="1" Background="White"
                                 Margin="0,0,0,16"/>

                        <!-- Botones -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="Cancelar"
                                    Command="{Binding CancelarFormularioCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="36"/>
                            <Button Grid.Column="2"
                                    Content="Guardar"
                                    Command="{Binding GuardarCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsEnabled="{Binding EstaCargando, Converter={StaticResource InverseBoolConverter}}"
                                    Height="36"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Mensaje éxito flotante -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,24" Padding="16,10"
                Background="#059669" CornerRadius="8"
                Visibility="{Binding MensajeExito, Converter={StaticResource NullToVisibilityConverter}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>
            <TextBlock Text="{Binding MensajeExito}" Foreground="White" FontSize="13"/>
        </Border>
    </Grid>
</UserControl>
