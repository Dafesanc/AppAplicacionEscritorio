<UserControl x:Class="GestionComercial.Presentation.Views.Modules.FacturasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- KPIs -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="⏳" FontSize="22" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding TotalPendiente, StringFormat=\${0:N2}}"
                               FontSize="22" FontWeight="Bold" Foreground="#F59E0B"/>
                    <TextBlock Text="Total pendiente de pago" FontSize="11" Foreground="#6B7280"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="🚨" FontSize="22" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CantidadVencidas}"
                               FontSize="24" FontWeight="Bold" Foreground="#EF4444"/>
                    <TextBlock Text="Facturas vencidas (+30 días)" FontSize="11" Foreground="#6B7280"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Filtros -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputStyle}"
                     Tag="🔍 Buscar por número de factura o cliente..."/>
            <ComboBox Grid.Column="2"
                      SelectedItem="{Binding FiltroEstado}"
                      Style="{StaticResource InputComboStyle}">
                <ComboBoxItem Content="TODOS"/>
                <ComboBoxItem Content="EMITIDA"/>
                <ComboBoxItem Content="CRÉDITO"/>
                <ComboBoxItem Content="PAGADA"/>
                <ComboBoxItem Content="ANULADA"/>
            </ComboBox>
        </Grid>

        <!-- Mensajes -->
        <TextBlock Grid.Row="2" Text="{Binding MensajeError}"
                   Foreground="#EF4444" FontSize="12" Margin="0,0,0,8"
                   Visibility="{Binding MensajeError, Converter={StaticResource NullToVisibilityConverter}}"/>
        <TextBlock Grid.Row="3" Text="{Binding MensajeExito}"
                   Foreground="#10B981" FontSize="12" Margin="0,0,0,8"
                   Visibility="{Binding MensajeExito, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Layout: tabla + panel pago -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding MostrarPago, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=300}"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid facturas -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#000" Opacity="0.05"/>
                </Border.Effect>
                <DataGrid ItemsSource="{Binding Facturas}"
                          SelectedItem="{Binding FacturaSeleccionada}"
                          Style="{StaticResource ModernDataGridStyle}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N° Factura"   Binding="{Binding NumeroFactura}"                              Width="140"/>
                        <DataGridTextColumn Header="Fecha"        Binding="{Binding FechaEmision, StringFormat=dd/MM/yyyy}"      Width="100"/>
                        <DataGridTextColumn Header="Vencimiento"  Binding="{Binding FechaVencimiento, StringFormat=dd/MM/yyyy}"  Width="110"/>
                        <DataGridTextColumn Header="Cliente"      Binding="{Binding ClienteNombre}"                             Width="*"/>
                        <DataGridTextColumn Header="Total"        Binding="{Binding TotalFactura, StringFormat=\${0:N2}}"        Width="110"/>
                        <DataGridTextColumn Header="Pendiente"    Binding="{Binding MontoPendiente, StringFormat=\${0:N2}}"      Width="110"/>
                        <DataGridTextColumn Header="Estado"       Binding="{Binding Estado}"                                    Width="90"/>
                        <DataGridTemplateColumn Header="Acciones" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Pagar" Height="28" Width="78" Margin="4,2"
                                            Style="{StaticResource PrimaryButtonStyle}" FontSize="11"
                                            Command="{Binding DataContext.RegistrarPagoCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Panel pago -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20"
                    Visibility="{Binding MostrarPago, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#000" Opacity="0.07"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Registrar Pago" FontSize="15" FontWeight="SemiBold"
                               Foreground="#1E3A5F" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding FacturaSeleccionada.NumeroFactura}"
                               FontSize="13" Foreground="#E8A020" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding FacturaSeleccionada.ClienteNombre}"
                               FontSize="12" Foreground="#6B7280" Margin="0,0,0,20"/>

                    <TextBlock Text="Total factura:" FontSize="12" Foreground="#374151"/>
                    <TextBlock Text="{Binding FacturaSeleccionada.TotalFactura, StringFormat=\${0:N2}}"
                               FontSize="20" FontWeight="Bold" Foreground="#1E3A5F" Margin="0,2,0,8"/>

                    <TextBlock Text="Pendiente:" FontSize="12" Foreground="#374151"/>
                    <TextBlock Text="{Binding FacturaSeleccionada.MontoPendiente, StringFormat=\${0:N2}}"
                               FontSize="18" FontWeight="Bold" Foreground="#EF4444" Margin="0,2,0,20"/>

                    <TextBlock Text="Monto recibido ($)" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding MontoRecibido, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}" Margin="0,0,0,20"/>

                    <Button Content="Confirmar Pago"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ConfirmarPagoCommand}"
                            Margin="0,0,0,8"/>
                    <Button Content="Cancelar"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding CancelarPagoCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
