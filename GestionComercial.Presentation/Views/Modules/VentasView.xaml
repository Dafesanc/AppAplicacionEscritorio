<UserControl x:Class="GestionComercial.Presentation.Views.Modules.VentasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- ===== CONTENIDO PRINCIPAL ===== -->
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra superior: botón Nueva Venta -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Button HorizontalAlignment="Right"
                        Content="+ Nueva Venta"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="150"
                        Command="{Binding NuevaVentaCommand}"/>
            </Grid>

            <!-- Filtros de fecha y estado -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="16,14" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#000" Opacity="0.05"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Desde:" VerticalAlignment="Center"
                               FontSize="12" Foreground="#374151" Margin="0,0,8,0"/>
                    <DatePicker Grid.Column="1"
                                SelectedDate="{Binding FiltroDesde}"
                                Height="40" FontSize="13"/>

                    <TextBlock Grid.Column="3" Text="Hasta:" VerticalAlignment="Center"
                               FontSize="12" Foreground="#374151" Margin="0,0,8,0"/>
                    <DatePicker Grid.Column="4"
                                SelectedDate="{Binding FiltroHasta}"
                                Height="40" FontSize="13"/>

                    <TextBox Grid.Column="6"
                             Text="{Binding FiltroCliente, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}"
                             Tag="🔍 Buscar cliente o número..."/>

                    <ComboBox Grid.Column="8"
                              ItemsSource="{Binding EstadosFiltro}"
                              SelectedItem="{Binding FiltroEstado}"
                              Style="{StaticResource InputComboStyle}"/>

                    <Button Grid.Column="10" Content="Buscar"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding BuscarCommand}"/>
                </Grid>
            </Border>

            <!-- Resumen -->
            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊 Ventas encontradas: " FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CantidadMostrada}" FontSize="18" FontWeight="Bold"
                                   Foreground="#1E3A5F" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💰 Total: " FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalMostrado, StringFormat=\${0:N2}}"
                                   FontSize="18" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Mensajes -->
            <TextBlock Grid.Row="3" Text="{Binding MensajeError}"
                       Foreground="#EF4444" FontSize="12" Margin="0,0,0,8"
                       Visibility="{Binding MensajeError, Converter={StaticResource NullToVisibilityConverter}}"/>
            <TextBlock Grid.Row="4" Text="{Binding MensajeExito}"
                       Foreground="#10B981" FontSize="12" Margin="0,0,0,8"
                       Visibility="{Binding MensajeExito, Converter={StaticResource NullToVisibilityConverter}}"/>

            <!-- DataGrid -->
            <Border Grid.Row="5" Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#000" Opacity="0.05"/>
                </Border.Effect>
                <DataGrid ItemsSource="{Binding Ventas}"
                          SelectedItem="{Binding VentaSeleccionada}"
                          Style="{StaticResource ModernDataGridStyle}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="N° Venta"  Binding="{Binding NumeroVenta}"                                  Width="140"/>
                        <DataGridTextColumn Header="Fecha"     Binding="{Binding FechaVenta, StringFormat=dd/MM/yyyy HH:mm}"    Width="140"/>
                        <DataGridTextColumn Header="Cliente"   Binding="{Binding ClienteNombre}"                                Width="*"/>
                        <DataGridTextColumn Header="Placa"     Binding="{Binding VehiculoPlaca}"                                Width="90"/>
                        <DataGridTextColumn Header="Peso Neto" Binding="{Binding PesoNetoKg, StringFormat={}{0:N2} kg}"         Width="100"/>
                        <DataGridTextColumn Header="Total"     Binding="{Binding TotalVenta, StringFormat=\${0:N2}}"            Width="110"/>
                        <DataGridTextColumn Header="Doc."      Binding="{Binding TipoDocumento}"                                Width="80"/>
                        <DataGridTextColumn Header="Estado"    Binding="{Binding Estado}"                                      Width="100"/>
                        <DataGridTemplateColumn Header="Acciones" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Completar" Height="28" Width="100" Margin="4,2"
                                            Style="{StaticResource SecondaryButtonStyle}" FontSize="11"
                                            Command="{Binding DataContext.CompletarVentaCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ===== MODAL OVERLAY ===== -->
        <Grid Background="#B2000000"
              Visibility="{Binding MostrarFormulario, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border MaxWidth="520"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="White" CornerRadius="16"
                    Margin="32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.30"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cabecera -->
                    <Grid Grid.Row="0" Margin="24,20,16,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="4" Height="20" Background="#F59E0B" CornerRadius="2" Margin="0,0,10,0"/>
                            <TextBlock Text="Nueva Venta"
                                       FontSize="17" FontWeight="Bold" Foreground="#1E3A5F"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                Content="✕" Width="32" Height="32"
                                Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                                FontSize="13" Foreground="#6B7280" Cursor="Hand"
                                Command="{Binding CancelarFormularioCommand}"/>
                    </Grid>
                    <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#F3F4F6" Margin="0,60,0,0"/>

                    <!-- Campos -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="560">
                        <StackPanel Margin="24,16,24,4">

                            <!-- Error en modal -->
                            <Border Background="#FEF2F2" CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                                    Visibility="{Binding MensajeError, Converter={StaticResource NullToVisibilityConverter}}">
                                <TextBlock Text="{Binding MensajeError}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Cliente -->
                            <TextBlock Text="Cliente *" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding FormClientes}"
                                      DisplayMemberPath="Nombre"
                                      SelectedValuePath="IdCliente"
                                      SelectedValue="{Binding FormIdCliente}"
                                      Style="{StaticResource InputComboStyle}"
                                      Margin="0,0,0,12"/>

                            <!-- Vehículo -->
                            <TextBlock Text="Vehículo (opcional)" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding FormVehiculos}"
                                      DisplayMemberPath="DescripcionCompleta"
                                      SelectedValuePath="IdVehiculo"
                                      SelectedValue="{Binding FormIdVehiculo}"
                                      Style="{StaticResource InputComboStyle}"
                                      Margin="0,0,0,12"/>

                            <!-- Producto -->
                            <TextBlock Text="Producto *" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding FormProductos}"
                                      DisplayMemberPath="Nombre"
                                      SelectedValuePath="IdProducto"
                                      SelectedValue="{Binding FormIdProducto}"
                                      Style="{StaticResource InputComboStyle}"
                                      Margin="0,0,0,12"/>

                            <!-- Descuento por defecto / Peso Tara Vehículo -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Descuento cliente (%)" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding FormDescuentoPct}"
                                             Style="{StaticResource InputStyle}"
                                             IsReadOnly="True"
                                             Background="#F3F4F6"
                                             Foreground="#6B7280"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Peso Tara Vehículo" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding FormPesoTaraVehiculo}"
                                             Style="{StaticResource InputStyle}"
                                             IsReadOnly="True"
                                             Background="#F3F4F6"
                                             Foreground="#6B7280"/>
                                </StackPanel>
                            </Grid>

                            <!-- Peso Neto / Unidad de Medida -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Peso Neto (kg)" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding FormPesoNeto, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Unidad de Medida" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding UnidadesMedida}"
                                              SelectedItem="{Binding FormUnidadMedida}"
                                              Style="{StaticResource InputComboStyle}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Tipo Documento -->
                            <TextBlock Text="Tipo Documento" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding TiposDocumento}"
                                      SelectedItem="{Binding FormTipoDocumento}"
                                      Style="{StaticResource InputComboStyle}"
                                      Margin="0,0,0,12"/>

                            <!-- Total / Descuento ($) -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Total ($) *" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding FormTotal, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Descuento ($)" FontSize="12" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding FormDescuento, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Botones footer -->
                    <Border Grid.Row="2" BorderBrush="#F3F4F6" BorderThickness="0,1,0,0" Padding="24,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Cancelar"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding CancelarFormularioCommand}"/>
                            <Button Grid.Column="2" Content="Guardar"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsEnabled="{Binding EstaCargando, Converter={StaticResource InverseBoolConverter}}"
                                    Command="{Binding GuardarVentaCommand}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
