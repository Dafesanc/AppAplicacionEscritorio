<UserControl x:Class="GestionComercial.Presentation.Views.Modules.VentasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filtros de fecha y estado -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16,14" Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#000" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Desde:" VerticalAlignment="Center"
                           FontSize="12" Foreground="#374151" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="1"
                            SelectedDate="{Binding FiltroDesde}"
                            Height="40" FontSize="13"/>

                <TextBlock Grid.Column="3" Text="Hasta:" VerticalAlignment="Center"
                           FontSize="12" Foreground="#374151" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="4"
                            SelectedDate="{Binding FiltroHasta}"
                            Height="40" FontSize="13"/>

                <TextBox Grid.Column="6"
                         Text="{Binding FiltroCliente, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputStyle}"
                         Tag="🔍 Buscar cliente o número..."/>

                <ComboBox Grid.Column="8"
                          SelectedItem="{Binding FiltroEstado}"
                          Style="{StaticResource InputComboStyle}">
                    <ComboBoxItem Content="TODOS"/>
                    <ComboBoxItem Content="BORRADOR"/>
                    <ComboBoxItem Content="COMPLETADA"/>
                    <ComboBoxItem Content="ANULADA"/>
                </ComboBox>

                <Button Grid.Column="10" Content="Buscar"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding BuscarCommand}"/>
            </Grid>
        </Border>

        <!-- Resumen -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📊 Ventas encontradas: " FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CantidadMostrada}" FontSize="18" FontWeight="Bold"
                               Foreground="#1E3A5F" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💰 Total: " FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalMostrado, StringFormat=\${0:N2}}"
                               FontSize="18" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Mensajes -->
        <TextBlock Grid.Row="2" Text="{Binding MensajeError}"
                   Foreground="#EF4444" FontSize="12" Margin="0,0,0,8"
                   Visibility="{Binding MensajeError, Converter={StaticResource NullToVisibilityConverter}}"/>
        <TextBlock Grid.Row="3" Text="{Binding MensajeExito}"
                   Foreground="#10B981" FontSize="12" Margin="0,0,0,8"
                   Visibility="{Binding MensajeExito, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- DataGrid -->
        <Border Grid.Row="4" Background="White" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#000" Opacity="0.05"/>
            </Border.Effect>
            <DataGrid ItemsSource="{Binding Ventas}"
                      SelectedItem="{Binding VentaSeleccionada}"
                      Style="{StaticResource ModernDataGridStyle}"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° Venta"    Binding="{Binding NumeroVenta}"              Width="140"/>
                    <DataGridTextColumn Header="Fecha"       Binding="{Binding FechaVenta, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                    <DataGridTextColumn Header="Cliente"     Binding="{Binding ClienteNombre}"            Width="*"/>
                    <DataGridTextColumn Header="Placa"       Binding="{Binding VehiculoPlaca}"            Width="90"/>
                    <DataGridTextColumn Header="Peso Neto"   Binding="{Binding PesoNetoKg, StringFormat={}{0:N2} kg}"  Width="100"/>
                    <DataGridTextColumn Header="Total"       Binding="{Binding TotalVenta, StringFormat=\${0:N2}}"     Width="110"/>
                    <DataGridTextColumn Header="Doc."        Binding="{Binding TipoDocumento}"            Width="80"/>
                    <DataGridTextColumn Header="Estado"      Binding="{Binding Estado}"                   Width="100"/>
                    <DataGridTemplateColumn Header="Acciones" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Completar" Height="28" Width="100" Margin="4,2"
                                        Style="{StaticResource SecondaryButtonStyle}" FontSize="11"
                                        Command="{Binding DataContext.CompletarVentaCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
