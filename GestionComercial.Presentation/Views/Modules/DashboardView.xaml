<UserControl x:Class="GestionComercial.Presentation.Views.Modules.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24">

            <!-- Saludo -->
            <TextBlock Text="{Binding Bienvenida}"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#1E3A5F" Margin="0,0,0,4"/>
            <TextBlock Text="Resumen general del sistema"
                       FontSize="13" Foreground="#6B7280"
                       Margin="0,0,0,24"/>

            <!-- ===== Tarjetas de estadísticas ===== -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Ventas hoy -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20,18">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0"
                                          Color="#000" Opacity="0.06"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="40" Height="40"
                                CornerRadius="10" HorizontalAlignment="Left">
                            <Border.Background>
                                <SolidColorBrush Color="#EFF6FF"/>
                            </Border.Background>
                            <TextBlock Text="🛒" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding TotalVentasHoy}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="#1E3A5F"/>
                        <TextBlock Grid.Row="4"
                                   Text="Ventas hoy"
                                   FontSize="12" Foreground="#6B7280"/>
                    </Grid>
                </Border>

                <!-- Clientes activos -->
                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20,18">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0"
                                          Color="#000" Opacity="0.06"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="40" Height="40"
                                CornerRadius="10" HorizontalAlignment="Left">
                            <Border.Background>
                                <SolidColorBrush Color="#F0FDF4"/>
                            </Border.Background>
                            <TextBlock Text="👥" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding TotalClientesActivos}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="#1E3A5F"/>
                        <TextBlock Grid.Row="4"
                                   Text="Clientes activos"
                                   FontSize="12" Foreground="#6B7280"/>
                    </Grid>
                </Border>

                <!-- Pesajes hoy -->
                <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="20,18">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0"
                                          Color="#000" Opacity="0.06"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="40" Height="40"
                                CornerRadius="10" HorizontalAlignment="Left">
                            <Border.Background>
                                <SolidColorBrush Color="#FFFBEB"/>
                            </Border.Background>
                            <TextBlock Text="⚖" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding PesajesHoy}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="#1E3A5F"/>
                        <TextBlock Grid.Row="4"
                                   Text="Pesajes hoy"
                                   FontSize="12" Foreground="#6B7280"/>
                    </Grid>
                </Border>

                <!-- Alertas de stock -->
                <Border Grid.Column="6" Background="White" CornerRadius="12" Padding="20,18">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0"
                                          Color="#000" Opacity="0.06"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="40" Height="40"
                                CornerRadius="10" HorizontalAlignment="Left">
                            <Border.Background>
                                <SolidColorBrush Color="#FFF1F2"/>
                            </Border.Background>
                            <TextBlock Text="⚠" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#EF4444"/>
                        </Border>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding AlertasStock}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="#EF4444"/>
                        <TextBlock Grid.Row="4"
                                   Text="Alertas de stock"
                                   FontSize="12" Foreground="#6B7280"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== Acciones rápidas ===== -->
            <TextBlock Text="Acciones rápidas"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="#1E3A5F" Margin="0,0,0,14"/>

            <WrapPanel>
                <Border Background="White" CornerRadius="10" Padding="16,14"
                        Margin="0,0,12,12" Cursor="Hand" Width="180">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="0"
                                          Color="#000" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="🛒" FontSize="24" Margin="0,0,0,8"/>
                        <TextBlock Text="Nueva Venta" FontWeight="SemiBold"
                                   FontSize="13" Foreground="#1E3A5F"/>
                        <TextBlock Text="Registrar nueva transacción"
                                   FontSize="11" Foreground="#9CA3AF"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Padding="16,14"
                        Margin="0,0,12,12" Cursor="Hand" Width="180">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="0"
                                          Color="#000" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="⚖" FontSize="24" Margin="0,0,0,8"/>
                        <TextBlock Text="Registrar Pesaje" FontWeight="SemiBold"
                                   FontSize="13" Foreground="#1E3A5F"/>
                        <TextBlock Text="Captura desde báscula"
                                   FontSize="11" Foreground="#9CA3AF"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Padding="16,14"
                        Margin="0,0,12,12" Cursor="Hand" Width="180">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="0"
                                          Color="#000" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="24" Margin="0,0,0,8"/>
                        <TextBlock Text="Nuevo Cliente" FontWeight="SemiBold"
                                   FontSize="13" Foreground="#1E3A5F"/>
                        <TextBlock Text="Registrar cliente y vehículo"
                                   FontSize="11" Foreground="#9CA3AF"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Padding="16,14"
                        Margin="0,0,12,12" Cursor="Hand" Width="180">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="0"
                                          Color="#000" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="24" Margin="0,0,0,8"/>
                        <TextBlock Text="Ver Inventario" FontWeight="SemiBold"
                                   FontSize="13" Foreground="#1E3A5F"/>
                        <TextBlock Text="Stock actual de productos"
                                   FontSize="11" Foreground="#9CA3AF"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
