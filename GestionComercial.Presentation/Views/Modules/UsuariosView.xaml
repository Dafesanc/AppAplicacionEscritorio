<UserControl x:Class="GestionComercial.Presentation.Views.Modules.UsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="{Binding MostrarFormulario, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=360}"/>
        </Grid.ColumnDefinitions>

        <!-- ===== PANEL PRINCIPAL ===== -->
        <Grid Grid.Column="0" Margin="24,20,12,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputStyle}"
                         Tag="🔍 Buscar por nombre, usuario o email..."/>
                <Button Grid.Column="2" Content="+ Nuevo Usuario"
                        Style="{StaticResource PrimaryButtonStyle}" Width="150"
                        Command="{Binding NuevoUsuarioCommand}"/>
            </Grid>

            <TextBlock Grid.Row="1" Text="{Binding MensajeError}"
                       Foreground="#EF4444" FontSize="12" Margin="0,0,0,8"
                       Visibility="{Binding MensajeError, Converter={StaticResource NullToVisibilityConverter}}"/>
            <TextBlock Grid.Row="2" Text="{Binding MensajeExito}"
                       Foreground="#10B981" FontSize="12" Margin="0,0,0,8"
                       Visibility="{Binding MensajeExito, Converter={StaticResource NullToVisibilityConverter}}"/>

            <Border Grid.Row="3" Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#000" Opacity="0.05"/>
                </Border.Effect>
                <DataGrid ItemsSource="{Binding Usuarios}"
                          SelectedItem="{Binding UsuarioSeleccionado}"
                          Style="{StaticResource ModernDataGridStyle}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Usuario"        Binding="{Binding NombreUsuario}"                              Width="130"/>
                        <DataGridTextColumn Header="Nombre completo" Binding="{Binding NombreCompleto}"                           Width="*"/>
                        <DataGridTextColumn Header="Email"          Binding="{Binding Email}"                                     Width="180"/>
                        <DataGridTextColumn Header="Rol"            Binding="{Binding RolNombre}"                                 Width="100"/>
                        <DataGridTextColumn Header="Estado"         Binding="{Binding Estado}"                                    Width="90"/>
                        <DataGridTextColumn Header="Último login"   Binding="{Binding UltimoLogin, StringFormat=dd/MM/yyyy HH:mm}" Width="130"/>
                        <DataGridTemplateColumn Header="Acciones" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                        <Button Content="Editar" Width="68" Height="28" Margin="0,0,4,0"
                                                Style="{StaticResource SecondaryButtonStyle}" FontSize="11"
                                                Command="{Binding DataContext.EditarUsuarioCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="Inactivar" Width="78" Height="28"
                                                Style="{StaticResource DangerButtonStyle}" FontSize="11"
                                                Command="{Binding DataContext.InactivarUsuarioCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ===== PANEL FORMULARIO ===== -->
        <Border Grid.Column="1" Background="White" CornerRadius="12"
                Margin="0,20,24,20" Padding="20"
                Visibility="{Binding MostrarFormulario, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#000" Opacity="0.07"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding EsEdicion, Converter={StaticResource BoolToLoadingTextConverter},
                                       ConverterParameter=Editar Usuario|Nuevo Usuario}"
                               FontSize="16" FontWeight="SemiBold" Foreground="#1E3A5F"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Nombre de usuario *" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FormNombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}"
                             IsEnabled="{Binding EsEdicion, Converter={StaticResource InverseBoolConverter}}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Nombre completo *" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FormNombreCompleto, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                    <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                    <TextBlock Text="Teléfono" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FormTelefono, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                    <TextBlock Text="Rol" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <ComboBox SelectedValue="{Binding FormRolId}"
                              SelectedValuePath="Tag"
                              Style="{StaticResource InputComboStyle}" Margin="0,0,0,12">
                        <ComboBoxItem Content="Administrador" Tag="1"/>
                        <ComboBoxItem Content="Operador"      Tag="2"/>
                        <ComboBoxItem Content="Consulta"      Tag="3"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Contraseña" FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                        <TextBlock Text=" (dejar vacío para no cambiar)" FontSize="12" Foreground="#9CA3AF"
                                   Visibility="{Binding EsEdicion, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                    <PasswordBox x:Name="PbContrasena"
                                 Style="{StaticResource PasswordStyle}"
                                 PasswordChanged="PbContrasena_PasswordChanged"
                                 Margin="0,0,0,20"/>

                    <TextBlock Text="{Binding MensajeError}" Foreground="#EF4444" FontSize="12"
                               Margin="0,0,0,8"
                               Visibility="{Binding MensajeError, Converter={StaticResource NullToVisibilityConverter}}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancelar"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding CancelarFormularioCommand}"/>
                        <Button Grid.Column="2" Content="Guardar"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding GuardarUsuarioCommand}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
