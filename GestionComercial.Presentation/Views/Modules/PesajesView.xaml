<UserControl x:Class="GestionComercial.Presentation.Views.Modules.PesajesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ===== PANEL IZQUIERDO: tabla de pesajes ===== -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Style="{StaticResource InputStyle}"
                         Tag="🔍 Buscar por placa..."/>
                <Button Grid.Column="2" Content="+ Registrar Pesaje"
                        Style="{StaticResource PrimaryButtonStyle}" Width="160"
                        Command="{Binding AbrirRegistroManualCommand}"/>
            </Grid>

            <TextBlock Grid.Row="1" Text="{Binding MensajeError}"
                       Foreground="#EF4444" FontSize="12" Margin="0,0,0,8"
                       Visibility="{Binding MensajeError, Converter={StaticResource NullToVisibilityConverter}}"/>
            <TextBlock Grid.Row="2" Text="{Binding MensajeExito}"
                       Foreground="#10B981" FontSize="12" Margin="0,0,0,8"
                       Visibility="{Binding MensajeExito, Converter={StaticResource NullToVisibilityConverter}}"/>

            <Border Grid.Row="3" Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#000" Opacity="0.05"/>
                </Border.Effect>
                <DataGrid ItemsSource="{Binding Pesajes}"
                          SelectedItem="{Binding PesajeSeleccionado}"
                          Style="{StaticResource ModernDataGridStyle}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"       Binding="{Binding IdPesaje}"             Width="60"/>
                        <DataGridTextColumn Header="Placa"    Binding="{Binding VehiculoPlaca}"         Width="100"/>
                        <DataGridTextColumn Header="Tipo"     Binding="{Binding Tipo}"                  Width="80"/>
                        <DataGridTextColumn Header="Peso (kg)" Binding="{Binding PesoKg, StringFormat={}{0:N2}}" Width="100"/>
                        <DataGridTextColumn Header="Ton."     Binding="{Binding PesoToneladas, StringFormat={}{0:N3}}" Width="80"/>
                        <DataGridTextColumn Header="Fecha"    Binding="{Binding FechaPesaje, StringFormat=dd/MM/yyyy HH:mm}" Width="*"/>
                        <DataGridTextColumn Header="Estado báscula" Binding="{Binding ObservacionesBascula}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ===== PANEL DERECHO: báscula + formulario ===== -->
        <StackPanel Grid.Column="2">

            <!-- Simulador báscula -->
            <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#000" Opacity="0.07"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="⚖" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Báscula" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#1E3A5F" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Display peso -->
                    <Border Background="#1E3A5F" CornerRadius="8" Padding="16,20" Margin="0,0,0,16">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding PesoBascula, StringFormat={}{0:N2}}"
                                       FontSize="36" FontWeight="Bold" Foreground="#E8A020"
                                       HorizontalAlignment="Center" FontFamily="Courier New"/>
                            <TextBlock Text="kg" FontSize="14" Foreground="#94A3B8"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding EstadoBascula}"
                               FontSize="12" Foreground="#6B7280"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>

                    <Button Content="📡 Leer Báscula"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SimularLecturaCommand}"
                            Margin="0,0,0,8"/>
                    <Button Content="Usar este peso"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding UsarPesoBasculaCommand}"/>
                </StackPanel>
            </Border>

            <!-- Formulario registro manual -->
            <Border Background="White" CornerRadius="12" Padding="20"
                    Visibility="{Binding MostrarRegistro, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#000" Opacity="0.07"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Registrar Pesaje" FontSize="15" FontWeight="SemiBold"
                               Foreground="#1E3A5F" Margin="0,0,0,16"/>

                    <TextBlock Text="ID Vehículo" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding VehiculoIdManual, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                    <TextBlock Text="Tipo de pesaje" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <ComboBox SelectedItem="{Binding TipoPesaje}"
                              Style="{StaticResource InputComboStyle}" Margin="0,0,0,12">
                        <ComboBoxItem Content="TARA"/>
                        <ComboBoxItem Content="BRUTO"/>
                    </ComboBox>

                    <TextBlock Text="Peso (kg)" FontSize="12" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PesoManual, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding MensajeError}" Foreground="#EF4444" FontSize="12"
                               Margin="0,0,0,8"
                               Visibility="{Binding MensajeError, Converter={StaticResource NullToVisibilityConverter}}"/>

                    <Button Content="Registrar Pesaje"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding RegistrarPesajeManualCommand}"
                            Margin="0,0,0,8"/>
                    <Button Content="Cancelar"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding CancelarRegistroCommand}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
