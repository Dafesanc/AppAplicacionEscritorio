<UserControl x:Class="GestionComercial.Presentation.Views.ChatBotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GestionComercial.Presentation.ViewModels">

    <UserControl.Resources>
        <!-- Botones rápidos de acción -->
        <Style x:Key="QuickActionStyle" TargetType="Button">
            <Setter Property="Background"      Value="#EFF6FF"/>
            <Setter Property="BorderBrush"     Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#1E3A5F"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Margin"          Value="0,0,6,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Plantilla de burbuja de mensaje -->
        <DataTemplate x:Key="MessageTemplate" DataType="{x:Type vm:ChatMessageItem}">
            <Border x:Name="bubble"
                    Margin="6,3"
                    Padding="10,7"
                    MaxWidth="268"
                    HorizontalAlignment="Left"
                    Background="#F1F5F9"
                    CornerRadius="14,14,14,4">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#000000" Opacity="0.05"/>
                </Border.Effect>
                <TextBlock x:Name="txt"
                           Text="{Binding Content}"
                           FontSize="12"
                           Foreground="#374151"
                           TextWrapping="Wrap"
                           LineHeight="18"/>
            </Border>
            <DataTemplate.Triggers>
                <!-- Mensaje del usuario: burbuja azul oscuro a la derecha -->
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter TargetName="bubble" Property="HorizontalAlignment" Value="Right"/>
                    <Setter TargetName="bubble" Property="Background"         Value="#1E3A5F"/>
                    <Setter TargetName="bubble" Property="CornerRadius"       Value="14,14,4,14"/>
                    <Setter TargetName="txt"    Property="Foreground"         Value="White"/>
                </DataTrigger>
                <!-- Burbuja de "pensando": gris más claro con cursiva -->
                <DataTrigger Binding="{Binding IsThinking}" Value="True">
                    <Setter TargetName="bubble" Property="Background"  Value="#E2E8F0"/>
                    <Setter TargetName="txt"    Property="FontStyle"   Value="Italic"/>
                    <Setter TargetName="txt"    Property="Foreground"  Value="#64748B"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid VerticalAlignment="Bottom" HorizontalAlignment="Right">

        <!-- ===== PANEL DE CHAT ===== -->
        <Border Width="360" Height="480"
                Margin="0,0,0,68"
                Background="White"
                CornerRadius="16,16,4,16"
                Visibility="{Binding ChatVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="#000000" Opacity="0.22"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="56"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="56"/>
                </Grid.RowDefinitions>

                <!-- Cabecera -->
                <Border Grid.Row="0" CornerRadius="16,16,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1E3A5F" Offset="0"/>
                            <GradientStop Color="#2563EB" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="16,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16" Background="#FFFFFF22" Margin="0,0,10,0">
                                <TextBlock Text="🤖" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Asistente Virtual" Foreground="White"
                                           FontSize="13" FontWeight="Bold"/>
                                <TextBlock Text="GestiónComercial" Foreground="#93C5FD" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- Botón cerrar panel -->
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                Content="✕" Width="28" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Foreground="White" FontSize="13" Cursor="Hand"
                                Command="{Binding ToggleChatCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="Transparent" CornerRadius="14">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#FFFFFF22"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Área de mensajes -->
                <ScrollViewer Grid.Row="1" x:Name="MessagesScroll"
                              VerticalScrollBarVisibility="Auto"
                              Padding="0,4">
                    <ItemsControl ItemsSource="{Binding Messages}"
                                  ItemTemplate="{StaticResource MessageTemplate}"/>
                </ScrollViewer>

                <!-- Acciones rápidas -->
                <Border Grid.Row="2" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0"
                        Padding="10,8">
                    <WrapPanel>
                        <Button Content="📊 Mis datos"
                                Style="{StaticResource QuickActionStyle}"
                                Command="{Binding VerMisDatosCommand}"/>
                        <Button Content="🐛 Soporte"
                                Style="{StaticResource QuickActionStyle}"
                                Command="{Binding IniciarSoporteCommand}"/>
                        <Button Content="🛒 Ventas"
                                Style="{StaticResource QuickActionStyle}"
                                Command="{Binding EnviarMensajeCommand}"
                                CommandParameter="Ir a ventas"/>
                        <Button Content="👥 Clientes"
                                Style="{StaticResource QuickActionStyle}"
                                Command="{Binding EnviarMensajeCommand}"
                                CommandParameter="Ir a clientes"/>
                    </WrapPanel>
                </Border>

                <!-- Área de entrada de texto -->
                <Border Grid.Row="3" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0"
                        Padding="10,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="20">
                            <TextBox x:Name="InputBox"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Padding="12,0"
                                     Height="36"
                                     FontSize="12"
                                     Tag="Escribe un mensaje...">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding EnviarMensajeCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Border>
                        <Button Grid.Column="1" Width="36" Height="36" Margin="6,0,0,0"
                                Command="{Binding EnviarMensajeCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                ToolTip="Enviar">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="18">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1E3A5F" Offset="0"/>
                                                <GradientStop Color="#2563EB" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="➤" FontSize="14" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="2,0,0,0"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ===== BOTÓN FLOTANTE ===== -->
        <Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Width="52" Height="52"
                Command="{Binding ToggleChatCommand}"
                ToolTip="Asistente Virtual">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Width="52" Height="52" CornerRadius="26">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1E3A5F" Offset="0"/>
                                <GradientStop Color="#2563EB" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="3" Color="#1E3A5F" Opacity="0.40"/>
                        </Border.Effect>
                        <TextBlock Text="🤖" FontSize="22" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</UserControl>
