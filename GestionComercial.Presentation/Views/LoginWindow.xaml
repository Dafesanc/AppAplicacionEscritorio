<Window x:Class="GestionComercial.Presentation.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Gestión Comercial"
        Height="580" Width="440"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Grid>
        <!-- Fondo degradado -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E3A5F" Offset="0"/>
                    <GradientStop Color="#0D1B2E" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Decoración: círculo superior derecho -->
        <Ellipse Width="200" Height="200"
                 HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,-60,-60,0" Opacity="0.08">
            <Ellipse.Fill>
                <SolidColorBrush Color="#E8A020"/>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Decoración: círculo inferior izquierdo -->
        <Ellipse Width="150" Height="150"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                 Margin="-40,0,0,-40" Opacity="0.06">
            <Ellipse.Fill>
                <SolidColorBrush Color="#E8A020"/>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Tarjeta de login -->
        <Border Background="White" CornerRadius="16"
                Margin="40,50,40,50" VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0"
                                  Color="#000000" Opacity="0.3"/>
            </Border.Effect>

            <Grid Margin="40,36,40,36">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Ícono/Logo -->
                <Border Grid.Row="0" Width="64" Height="64"
                        CornerRadius="16" HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E3A5F" Offset="0"/>
                            <GradientStop Color="#2A4E7F" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="⚖" FontSize="30"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#E8A020"/>
                </Border>

                <!-- Título -->
                <TextBlock Grid.Row="1"
                           Text="Gestión Comercial"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#1E3A5F"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>

                <!-- Subtítulo -->
                <TextBlock Grid.Row="2"
                           Text="Materiales de Construcción"
                           FontSize="12" Foreground="#6B7280"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- Campo usuario -->
                <StackPanel Grid.Row="3" Margin="0,0,0,14">
                    <TextBlock Text="Usuario" FontSize="12"
                               FontWeight="SemiBold" Foreground="#374151"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtUsuario"
                             Style="{StaticResource InputStyle}"
                             Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Ingrese su usuario"/>
                </StackPanel>

                <!-- Campo contraseña -->
                <StackPanel Grid.Row="4" Margin="0,0,0,6">
                    <TextBlock Text="Contraseña" FontSize="12"
                               FontWeight="SemiBold" Foreground="#374151"
                               Margin="0,0,0,6"/>
                    <Grid>
                        <!-- PasswordBox (modo oculto) -->
                        <PasswordBox x:Name="TxtContrasena"
                                     Style="{StaticResource PasswordStyle}"
                                     PasswordChanged="TxtContrasena_PasswordChanged"/>

                        <!-- TextBox (modo visible) -->
                        <TextBox x:Name="TxtContrasenaVisible"
                                 Style="{StaticResource InputStyle}"
                                 TextChanged="TxtContrasenaVisible_TextChanged"
                                 Visibility="Collapsed"/>

                        <!-- Botón ojo -->
                        <Button x:Name="BtnToggleContrasena"
                                Width="36" Height="36"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,2,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnToggleContrasena_Click"
                                Panel.ZIndex="1">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="Transparent"
                                                        CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#18000000"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock x:Name="IconoOjo" Text="👁"
                                       FontSize="15" Foreground="#9CA3AF"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Mensaje de error -->
                <TextBlock Grid.Row="5"
                           Text="{Binding MensajeError}"
                           Foreground="#EF4444"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"
                           Visibility="{Binding MensajeError,
                               Converter={StaticResource NullToVisibilityConverter}}"/>

                <!-- Espacio flexible -->
                <Grid Grid.Row="6" Height="12"/>

                <!-- Botón de login -->
                <Button Grid.Row="7"
                        Content="{Binding EstaCargando,
                            Converter={StaticResource BoolToLoadingTextConverter},
                            ConverterParameter=Iniciando sesión...|Ingresar al Sistema}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding IniciarSesionCommand}"
                        IsEnabled="{Binding EstaCargando,
                            Converter={StaticResource InverseBoolConverter}}"
                        Margin="0,0,0,0"/>
            </Grid>
        </Border>

        <!-- Versión en la parte inferior -->
        <TextBlock Text="v1.0.0 © 2026"
                   Foreground="#FFFFFF" Opacity="0.4"
                   FontSize="10"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,10"/>

        <!-- Botón cerrar (esquina superior derecha) -->
        <Button Content="✕"
                Width="32" Height="32"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,8,0"
                Background="Transparent"
                Foreground="White"
                BorderThickness="0"
                FontSize="14"
                Cursor="Hand"
                Click="BtnCerrar_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                        CornerRadius="4" Width="28" Height="28">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#44FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
