<Window x:Class="GestionComercial.Presentation.Views.MainShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="Sistema de Gestión Comercial"
        Height="780" Width="1280"
        MinHeight="640" MinWidth="1024"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Estilo de botón de navegación en sidebar -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"       Value="46"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"      Value="20,0,0,0"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,0">
                            <Grid>
                                <!-- Indicador lateral izquierdo (activo) -->
                                <Rectangle x:Name="indicator"
                                           Width="4" HorizontalAlignment="Left"
                                           Fill="#E8A020" Opacity="0"
                                           RadiusX="2" RadiusY="2"/>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A4E7F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="bd" Property="Background" Value="#2A4E7F"/>
                                <Setter TargetName="indicator" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== SIDEBAR ========== -->
        <Grid Grid.Column="0" Background="#1E3A5F">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo / empresa -->
            <Border Grid.Row="0" Padding="20,24,20,20"
                    BorderBrush="#2A4E7F" BorderThickness="0,0,0,1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="10"
                                Background="#E8A020" Margin="0,0,10,0">
                            <TextBlock Text="⚖" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="White"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="GestiónComercial"
                                       Foreground="White" FontSize="14"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Materiales"
                                       Foreground="#94A3B8" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Menú de navegación -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel Margin="0,12,0,0">

                    <TextBlock Text="MENÚ PRINCIPAL"
                               Foreground="#475569" FontSize="10"
                               FontWeight="SemiBold"
                               Margin="20,0,0,8"/>

                    <Button Tag="{Binding DashboardSeleccionado,
                                    Converter={StaticResource BoolToActiveTagConverter}}"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding IrDashboardCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" Width="22" FontSize="15"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="{Binding VentasSeleccionado,
                                    Converter={StaticResource BoolToActiveTagConverter}}"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding IrVentasCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛒" Width="22" FontSize="15"/>
                            <TextBlock Text="Ventas" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="{Binding PesajesSeleccionado,
                                    Converter={StaticResource BoolToActiveTagConverter}}"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding IrPesajesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚖" Width="22" FontSize="15"/>
                            <TextBlock Text="Pesajes / Báscula" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="{Binding ClientesSeleccionado,
                                    Converter={StaticResource BoolToActiveTagConverter}}"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding IrClientesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" Width="22" FontSize="15"/>
                            <TextBlock Text="Clientes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="{Binding InventarioSeleccionado,
                                    Converter={StaticResource BoolToActiveTagConverter}}"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding IrInventarioCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" Width="22" FontSize="15"/>
                            <TextBlock Text="Inventario" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="{Binding FacturasSeleccionado,
                                    Converter={StaticResource BoolToActiveTagConverter}}"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding IrFacturasCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧾" Width="22" FontSize="15"/>
                            <TextBlock Text="Facturación" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="{Binding UsuariosSeleccionado,
                                    Converter={StaticResource BoolToActiveTagConverter}}"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding IrUsuariosCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" Width="22" FontSize="15"/>
                            <TextBlock Text="Usuarios" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Tag="{Binding VehiculosSeleccionado,
                                    Converter={StaticResource BoolToActiveTagConverter}}"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding IrVehiculosCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚛" Width="22" FontSize="15"/>
                            <TextBlock Text="Vehículos" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer del sidebar: info usuario + cerrar sesión -->
            <Border Grid.Row="2" BorderBrush="#2A4E7F" BorderThickness="0,1,0,0"
                    Padding="16,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Info del usuario -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="18"
                                Background="#2A4E7F" Margin="0,0,10,0">
                            <TextBlock Text="👤" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding UsuarioNombre}"
                                       Foreground="White" FontSize="12"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="130"/>
                            <TextBlock Text="{Binding UsuarioRol}"
                                       Foreground="#94A3B8" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Botón cerrar sesión -->
                    <Button Grid.Row="2"
                            Command="{Binding CerrarSesionCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#EF444422"
                            Foreground="#FCA5A5"
                            BorderThickness="0"
                            Height="34"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd"
                                                    Background="#22EF4444"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#44EF4444"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏏" FontSize="13" Margin="0,0,6,0"
                                       Foreground="#FCA5A5"/>
                            <TextBlock Text="Cerrar sesión" FontSize="12"
                                       Foreground="#FCA5A5" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== ÁREA DE CONTENIDO ========== -->
        <Grid Grid.Column="1" Background="#F0F2F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header superior -->
            <Border Grid.Row="0" Background="White"
                    BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left"
                                Orientation="Horizontal">
                        <TextBlock Text="{Binding TituloModulo}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#1E3A5F" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now},
                                       StringFormat='📅 {0:dd/MM/yyyy}'}"
                                   Foreground="#6B7280" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Contenido dinámico (cambia según el módulo seleccionado) -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentViewModel}"/>
        </Grid>
    </Grid>
</Window>
